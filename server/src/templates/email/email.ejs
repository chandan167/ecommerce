<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        @import url('https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.css');
    </style>
</head>
<title>Document</title>
</head>

<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-7 bg-light p-5 my-5">
                <div class="m-4">
                    <h1 class="text-center"><%= templateTitle %></h1>
                </div>
                <hr>
                <% if(heading && Array.isArray(heading)) { %>
                    <% heading.forEach(data=>{ %>
                        <h6 class="mb-3">
                            <%= data %>
                        </h6>
                        <% }) %>
                            <% } %>

                                <% if(paragraph && Array.isArray(paragraph)) { %>
                                    <% paragraph.forEach(data=>{ %>
                                        <p class="my-2">
                                            <%= data %>
                                        </p>
                                        <% }) %>
                                            <% } %>



                                                <div class="d-flex justify-content-center my-4">
                                                    <% if(button && Array.isArray(button)) { %>
                                                        <% button.forEach(data=>{ %>
                                                            <a href="<%= data.url %>" class="btn btn-dark m-2"
                                                                target="_blank" rel="noopener noreferrer">
                                                                <%= data.text %>
                                                            </a>
                                                            <% }) %>
                                                                <% } %>

                                                </div>

                                                <% if(button && Array.isArray(button)) { %>
                                                    <% button.forEach(data=>{ %>
                                                        <p>
                                                            <a href="<%= data.url %>" target="_blank"
                                                                rel="noopener noreferrer">
                                                                <%= data.url %>
                                                            </a>
                                                        </p>

                                                        <% }) %>
                                                            <% } %>
                                                                <hr>
            </div>
        </div>
    </div>
</body>

</html>